generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum ItemStatus {
  ACTIVE
  TRADED
  REMOVED
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  FOR_PARTS
}

enum TradeStatus {
  MATCHED
  IN_PROGRESS
  COMPLETED
  STALE
}

enum SwipeDirection {
  RIGHT
  LEFT
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String?
  image         String?
  provider      AuthProvider @default(CREDENTIALS)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastActiveAt  DateTime @default(now())
  streakDays    Int      @default(0)
  streakLastDate DateTime?

  items           Item[]
  swipes          Swipe[]
  tradeMembers    TradeMember[]
  circlesCreated  Circle[]       @relation("CircleAdmin")
  circleMemberships CircleMember[]
  likes           Like[]
  comments        Comment[]
}

model Circle {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique
  adminId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin       User     @relation("CircleAdmin", fields: [adminId], references: [id])
  members     CircleMember[]
  swipes      Swipe[]
  trades      Trade[]

  @@index([inviteCode])
}

model CircleMember {
  id        String   @id @default(cuid())
  circleId  String
  userId    String
  joinedAt  DateTime @default(now())
  invitedBy String?

  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([userId])
  @@index([circleId])
}

model Item {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  condition   ItemCondition?
  tags        String[]
  images      String[]
  status      ItemStatus   @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tradedAt    DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  swipes      Swipe[]
  givenInTrades  TradeMember[] @relation("GivenItem")
  receivedInTrades TradeMember[] @relation("ReceivedItem")
  likes       Like[]
  comments    Comment[]

  @@index([userId])
  @@index([status])
}

model Swipe {
  id        String         @id @default(cuid())
  userId    String
  itemId    String
  circleId  String
  direction SwipeDirection
  undone    Boolean        @default(false)
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  circle    Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId, circleId])
  @@index([userId, circleId])
  @@index([itemId])
}

model Trade {
  id          String      @id @default(cuid())
  circleId    String
  status      TradeStatus @default(MATCHED)
  cycleLength Int
  score       Float       @default(0)
  matchedAt   DateTime    @default(now())
  completedAt DateTime?
  deadline    DateTime

  circle      Circle      @relation(fields: [circleId], references: [id])
  members     TradeMember[]

  @@index([circleId])
  @@index([status])
}

model TradeMember {
  id             String    @id @default(cuid())
  tradeId        String
  userId         String
  givesItemId    String
  receivesItemId String
  completedAt    DateTime?

  trade          Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id])
  givesItem      Item      @relation("GivenItem", fields: [givesItemId], references: [id])
  receivesItem   Item      @relation("ReceivedItem", fields: [receivesItemId], references: [id])

  @@unique([tradeId, userId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  @@unique([userId, itemId])
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  itemId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}